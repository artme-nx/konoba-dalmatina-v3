{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "ink": {
        "950": { "$value": "#170B0D", "$type": "color" },
        "900": { "$value": "#221115", "$type": "color" },
        "800": { "$value": "#35191E", "$type": "color" },
        "700": { "$value": "#4C2831", "$type": "color" }
      },
      "bone": {
        "100": { "$value": "#F5EEE2", "$type": "color" },
        "300": { "$value": "#DFC9AE", "$type": "color" },
        "500": { "$value": "#A6907A", "$type": "color" }
      },
      "olive": {
        "500": { "$value": "#A99143", "$type": "color" },
        "700": { "$value": "#7C6B2E", "$type": "color" },
        "900": { "$value": "#3A331A", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-cormorant), 'Cormorant Garamond', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-figtree), 'Figtree', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.28em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.ink.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.bone.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.ink.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "border": { "$value": "{primitive.color.ink.700}", "$type": "color" },
    "ring": { "$value": "{primitive.color.olive.500}", "$type": "color" },
    "radius": { "$value": "0.7rem", "$type": "dimension" },
    "brass": { "$value": "{primitive.color.olive.500}", "$type": "color" },
    "brass-dim": { "$value": "{primitive.color.olive.900}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.ink.700}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.7rem, 7vw, 5.8rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.04", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 70% 50% at 50% 100%, rgba(169, 145, 67, 0.20), rgba(58, 51, 26, 0.1) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(23, 11, 13, 0.96) 0%, rgba(23, 11, 13, 0.32) 42%, rgba(23, 11, 13, 0.58) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.olive.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.ink.950}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.bone.100}", "$type": "color" },
      "ghost-border": { "$value": "rgba(245, 238, 226, 0.35)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.olive.500}", "$type": "color" }
    }
  }
}
